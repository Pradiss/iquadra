generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatusUsuario {
  ATIVO
  INATIVO
  BLOQUEADO
}

enum PerfilAcademiaUsuario {
  PROFESSOR
  FUNCIONARIO
  ADMIN_ACADEMIA
  DONO
}

enum CategoriaUsuario {
  A
  B
  C
  D
  INICIANTE
}

enum TipoPiso {
  SAIBRO
  HARD
  GRAMA
  SINTETICA
  AREIA
  OUTRO
}

enum ModalidadeQuadra {
  TENIS
  BEACH_TENNIS
  PADEL
  PICKLEBALL
  OUTRO
}

enum TipoJogo {
  SIMPLES
  DUPLA
}

enum StatusJogo {
  ABERTO
  COMPLETO
  CANCELADO
  CONCLUIDO
  SEM_PARTICIPANTES
  NAO_COMPARECEU
}

enum PapelParticipante {
  CRIADOR
  JOGADOR
}

enum StatusParticipante {
  CONFIRMADO
  SAIU
  REMOVIDO
}

enum StatusAula {
  CONFIRMADA
  CANCELADA
  CONCLUIDA
}

enum StatusRecorrencia {
  ATIVA
  CANCELADA
  FINALIZADA
}

enum PeriodoLimiteJogos {
  DIA
  SEMANA
  MES
}

enum AuthTokenTipo {
  ATIVACAO
  RESET_SENHA
}

enum StatusAmizade {
  PENDENTE
  ACEITA
  RECUSADA
  BLOQUEADA
}

enum StatusConviteJogo {
  PENDENTE
  ACEITO
  RECUSADO
  CANCELADO
}

enum StatusAssinatura {
  TESTE
  ATIVA
  ATRASADA
  CANCELADA
}

enum TipoBloqueio {
  MANUTENCAO
  EVENTO
  FERIADO
  PARTICULAR
  OUTRO
}

model Usuario {
  id             String  @id @default(uuid())
  supabaseUserId String? @unique @map("supabase_user_id")
  nome           String
  email          String  @unique
  telefone       String
  senha_hash     String?

  foto_perfil String?
  fotoUrl     String? @map("foto_url")
  fotoPath    String? @map("foto_path")

  status StatusUsuario @default(ATIVO)

  perfil_cliente   PerfilCliente?
  perfil_professor PerfilProfessor?

  academias AcademiaUsuario[]

  jogos_criados       Jogo[]             @relation("JogosCriados")
  jogos_responsavel   Jogo[]             @relation("JogosResponsavel")
  participantes_jogos ParticipanteJogo[]

  aulas_cliente   Aula[] @relation("AulasCliente")
  aulas_professor Aula[] @relation("AulasProfessor")

  bloqueios_criados BloqueioQuadra[]
  logs              LogAuditoria[]
  tokens            AuthToken[]

  amizades_enviadas  Amizade[] @relation("AmizadesEnviadas")
  amizades_recebidas Amizade[] @relation("AmizadesRecebidas")

  convites_recebidos ConviteJogo[] @relation("ConvitesRecebidos")
  convites_enviados  ConviteJogo[] @relation("ConvitesEnviados")

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@map("usuarios")
}

model PerfilCliente {
  id         String @id @default(uuid())
  usuario_id String @unique

  categoria CategoriaUsuario
  cidade    String
  cep       String

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@map("perfis_clientes")
}

model PerfilProfessor {
  id         String @id @default(uuid())
  usuario_id String @unique

  bio            String?
  especialidades String?
  cidade         String?

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@map("perfis_professores")
}

model Academia {
  id   String  @id @default(uuid())
  nome String
  slug String  @unique
  cnpj String? @unique

  telefone String?
  email    String?

  endereco String?
  cidade   String?
  estado   String?
  cep      String?
  logoPath String? @map("logo_path")

  status StatusUsuario @default(ATIVO)

  limite_jogos_padrao  Int                @default(3)
  periodo_limite_jogos PeriodoLimiteJogos @default(SEMANA)
  duracoes_reserva_minutos Int[]              @default([60, 90, 120])

  usuarios           AcademiaUsuario[]
  quadras            Quadra[]
  jogos              Jogo[]
  aulas              Aula[]
  recorrencias_aulas RecorrenciaAula[]
  assinaturas        AssinaturaAcademia[]
  logs               LogAuditoria[]

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@map("academias")
}

model AcademiaUsuario {
  id          String @id @default(uuid())
  academia_id String
  usuario_id  String

  perfil PerfilAcademiaUsuario
  status StatusUsuario         @default(ATIVO)

  limite_jogos_personalizado Int?

  academia Academia @relation(fields: [academia_id], references: [id])
  usuario  Usuario  @relation(fields: [usuario_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@unique([academia_id, usuario_id])
  @@index([usuario_id])
  @@index([academia_id, perfil])
  @@map("academia_usuarios")
}

model AuthToken {
  id         String @id @default(uuid())
  usuario_id String

  token_hash String        @unique
  tipo       AuthTokenTipo
  expira_em  DateTime
  usado_em   DateTime?

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([usuario_id, tipo, expira_em])
  @@map("auth_tokens")
}

model Quadra {
  id          String @id @default(uuid())
  academia_id String

  nome           String
  descricao      String?
  tipo_piso      TipoPiso
  modalidade     ModalidadeQuadra?
  valor_hora     Float?
  coberta        Boolean  @default(false)
  ativa          Boolean  @default(true)
  ordem_exibicao Int      @default(0)

  capacidade_minima Int     @default(2)
  capacidade_maxima Int     @default(4)
  permite_simples   Boolean @default(true)
  permite_dupla     Boolean @default(true)

  academia Academia @relation(fields: [academia_id], references: [id])

  horarios           HorarioQuadra[]
  horarios_especiais HorarioEspecialQuadra[]
  bloqueios          BloqueioQuadra[]
  jogos              Jogo[]
  aulas              Aula[]
  recorrencias_aulas RecorrenciaAula[]

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([academia_id])
  @@index([academia_id, ativa, ordem_exibicao])
  @@map("quadras")
}

model HorarioQuadra {
  id        String @id @default(uuid())
  quadra_id String

  dia_semana Int
  abre_as    String
  fecha_as   String

  duracao_slot_minutos Int     @default(60)
  ativo                Boolean @default(true)

  quadra Quadra @relation(fields: [quadra_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([quadra_id, dia_semana])
  @@map("horarios_quadras")
}

model HorarioEspecialQuadra {
  id        String @id @default(uuid())
  quadra_id String

  data     DateTime
  abre_as  String?
  fecha_as String?
  fechada  Boolean  @default(false)
  motivo   String?

  quadra Quadra @relation(fields: [quadra_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([quadra_id, data])
  @@map("horarios_especiais_quadras")
}

model BloqueioQuadra {
  id        String @id @default(uuid())
  quadra_id String

  inicio_em DateTime
  fim_em    DateTime

  tipo_bloqueio TipoBloqueio @default(OUTRO)
  motivo        String

  criado_por_usuario_id String

  quadra     Quadra  @relation(fields: [quadra_id], references: [id])
  criado_por Usuario @relation(fields: [criado_por_usuario_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([quadra_id, inicio_em, fim_em])
  @@map("bloqueios_quadras")
}

model Jogo {
  id          String @id @default(uuid())
  academia_id String
  quadra_id   String

  criado_por_usuario_id  String
  responsavel_usuario_id String

  tipo_jogo TipoJogo
  inicio_em DateTime
  fim_em    DateTime

  status StatusJogo @default(ABERTO)

  maximo_participantes Int

  observacoes          String?
  observacoes_internas String?

  academia Academia @relation(fields: [academia_id], references: [id])
  quadra   Quadra   @relation(fields: [quadra_id], references: [id])

  criado_por  Usuario @relation("JogosCriados", fields: [criado_por_usuario_id], references: [id])
  responsavel Usuario @relation("JogosResponsavel", fields: [responsavel_usuario_id], references: [id])

  participantes ParticipanteJogo[]
  convites      ConviteJogo[]

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([academia_id])
  @@index([academia_id, status, inicio_em])
  @@index([quadra_id, inicio_em, fim_em])
  @@index([quadra_id, status, inicio_em, fim_em])
  @@index([criado_por_usuario_id])
  @@map("jogos")
}

model ParticipanteJogo {
  id         String @id @default(uuid())
  jogo_id    String
  usuario_id String

  papel  PapelParticipante  @default(JOGADOR)
  status StatusParticipante @default(CONFIRMADO)

  jogo    Jogo    @relation(fields: [jogo_id], references: [id])
  usuario Usuario @relation(fields: [usuario_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@unique([jogo_id, usuario_id])
  @@index([jogo_id, status])
  @@index([usuario_id])
  @@index([usuario_id, status])
  @@map("participantes_jogos")
}

model ConviteJogo {
  id String @id @default(uuid())

  jogo_id              String
  convidado_usuario_id String
  enviado_por_id       String

  status StatusConviteJogo @default(PENDENTE)

  jogo       Jogo    @relation(fields: [jogo_id], references: [id])
  convidado  Usuario @relation("ConvitesRecebidos", fields: [convidado_usuario_id], references: [id])
  enviadoPor Usuario @relation("ConvitesEnviados", fields: [enviado_por_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@unique([jogo_id, convidado_usuario_id])
  @@index([convidado_usuario_id])
  @@index([convidado_usuario_id, status, criado_em])
  @@index([enviado_por_id])
  @@index([jogo_id, status])
  @@map("convites_jogos")
}

model Aula {
  id          String @id @default(uuid())
  academia_id String
  quadra_id   String

  cliente_id   String?
  professor_id String?

  inicio_em DateTime
  fim_em    DateTime

  status StatusAula @default(CONFIRMADA)

  recorrente     Boolean @default(false)
  recorrencia_id String?

  observacoes String?

  academia Academia @relation(fields: [academia_id], references: [id])
  quadra   Quadra   @relation(fields: [quadra_id], references: [id])

  cliente   Usuario? @relation("AulasCliente", fields: [cliente_id], references: [id])
  professor Usuario? @relation("AulasProfessor", fields: [professor_id], references: [id])

  recorrencia RecorrenciaAula? @relation(fields: [recorrencia_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([academia_id])
  @@index([academia_id, status, inicio_em])
  @@index([quadra_id, inicio_em, fim_em])
  @@index([quadra_id, status, inicio_em, fim_em])
  @@index([professor_id])
  @@index([cliente_id])
  @@map("aulas")
}

model RecorrenciaAula {
  id          String @id @default(uuid())
  academia_id String
  quadra_id   String

  professor_id String?

  dias_semana String

  data_inicio DateTime
  data_fim    DateTime?

  horario_inicio String
  horario_fim    String

  status StatusRecorrencia @default(ATIVA)

  academia Academia @relation(fields: [academia_id], references: [id])
  quadra   Quadra   @relation(fields: [quadra_id], references: [id])

  aulas Aula[]

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([academia_id])
  @@index([quadra_id])
  @@map("recorrencias_aulas")
}

model Amizade {
  id String @id @default(uuid())

  usuario_id String
  amigo_id   String

  status StatusAmizade @default(PENDENTE)

  usuario Usuario @relation("AmizadesEnviadas", fields: [usuario_id], references: [id])
  amigo   Usuario @relation("AmizadesRecebidas", fields: [amigo_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@unique([usuario_id, amigo_id])
  @@index([amigo_id])
  @@map("amizades")
}

model AssinaturaAcademia {
  id          String @id @default(uuid())
  academia_id String

  plano  String
  status StatusAssinatura @default(TESTE)

  valor Decimal? @db.Decimal(10, 2)

  inicio_em DateTime  @default(now())
  fim_em    DateTime?

  academia Academia @relation(fields: [academia_id], references: [id])

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@index([academia_id, status])
  @@map("assinaturas_academias")
}

model LogAuditoria {
  id          String  @id @default(uuid())
  academia_id String?
  usuario_id  String?

  acao        String
  entidade    String
  entidade_id String
  metadata    Json?

  academia Academia? @relation(fields: [academia_id], references: [id])
  usuario  Usuario?  @relation(fields: [usuario_id], references: [id])

  criado_em DateTime @default(now())

  @@index([academia_id])
  @@index([usuario_id])
  @@index([entidade, entidade_id])
  @@map("logs_auditoria")
}
